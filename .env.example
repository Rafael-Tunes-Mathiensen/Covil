# Configuração pública usada somente no desenvolvimento local.
# A chave anon pode estar no navegador porque a autorização continua protegida por RLS.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: URLs STUN/TURN separadas por vírgula.
VITE_ICE_SERVERS=stun:stun.l.google.com:19302

# Também aceita RTCIceServer[] em JSON, por exemplo:
# VITE_ICE_SERVERS=[{"urls":"turn:turn.example.net:3478","username":"temporary-user","credential":"temporary-credential"}]
# Nunca use credenciais TURN permanentes aqui.
# No Sites, configure SUPABASE_URL, SUPABASE_ANON_KEY e ICE_SERVERS sem VITE_.
