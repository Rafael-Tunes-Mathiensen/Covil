# Public project coordinates. The anon key is safe in the browser only when RLS remains enabled.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional comma-separated TURN/STUN URLs. Never put a long-lived TURN secret here.
VITE_ICE_SERVERS=stun:stun.l.google.com:19302
